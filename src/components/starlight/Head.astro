---
// Overrides Starlight's default Head to add Astro's View Transitions router,
// so navigation between /docs pages AND between docs <-> the landing is a
// soft (SPA-like) navigation instead of a full page reload.
import Default from "@astrojs/starlight/components/Head.astro";
import { ClientRouter } from "astro:transitions";
---

<Default><slot /></Default>
<ClientRouter />
