---
interface Props {
  number      : string;
  title       : string;
  description : string;
  class      ?: string;
}

const { number, title, description, class: className } = Astro.props;
---

<div
  class:list={[
    "feature-cell group relative flex flex-col overflow-hidden rounded-3xl border border-brand-900/5 bg-white p-8 shadow-[0_8px_30px_-12px_rgba(29,37,112,0.12)] transition-colors hover:border-brand-900/10 lg:p-9",
    className,
  ]}
>
  <span
    class="absolute top-5 right-6 z-10 font-mono text-[0.65rem] text-brand-300/70"
  >
    {number}
  </span>

  <slot />

  <h3 class="font-display text-lg font-bold text-brand-900">{title}</h3>
  
  <p class="mt-2 text-sm leading-relaxed text-brand-600">{description}</p>
</div>
