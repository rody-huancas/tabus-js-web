---
import BusVisual from "./visuals/BusVisual.astro";
import TinyVisual from "./visuals/TinyVisual.astro";
import FeatureCard from "./FeatureCard.astro";
import FallbackVisual from "./visuals/FallbackVisual.astro";
import ThrottleVisual from "./visuals/ThrottleVisual.astro";
import ZeroDepsVisual from "./visuals/ZeroDepsVisual.astro";
import TypedEventsVisual from "./visuals/TypedEventsVisual.astro";
import { featuresMeta } from "./features.data";
import type { FeatureVisualId } from "./features.data";
import { landing, type Locale } from "../../../i18n/landing";

interface Props {
  locale?: Locale;
}

const { locale = "es" } = Astro.props;
const t = landing[locale];

const visualComponents: Record<FeatureVisualId, unknown> = {
  fallback      : FallbackVisual,
  "typed-events": TypedEventsVisual,
  throttle      : ThrottleVisual,
  "zero-deps"   : ZeroDepsVisual,
  tiny          : TinyVisual,
};
---

<section class="mx-auto max-w-360 px-6 py-20 lg:px-12 lg:py-28">
  <div class="mx-auto mb-14 max-w-2xl text-center lg:mb-16">
    <h2 class="font-display text-3xl font-bold text-brand-900 sm:text-4xl">
      {t.features.heading}
    </h2>

    <p class="mt-4 text-lg text-brand-700/90">
      {t.features.subhead}
    </p>
  </div>

  <div
    class="features-grid grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8 lg:grid-cols-3 lg:gap-10"
  >
    <div
      class="feature-cell group relative flex flex-col gap-8 overflow-hidden rounded-3xl border border-brand-900/5 bg-white p-8 shadow-[0_8px_30px_-12px_rgba(29,37,112,0.12)] transition-colors hover:border-brand-900/10 sm:col-span-2 lg:col-span-2 lg:row-span-2 lg:flex-row lg:items-stretch lg:gap-10 lg:p-11"
    >
      <span
        class="absolute top-6 right-7 z-10 font-mono text-[0.65rem] text-brand-300/70"
      >
        01
      </span>

      <div class="flex flex-col justify-center lg:w-[38%] lg:shrink-0">
        <h3 class="font-display text-2xl font-bold text-brand-900 lg:text-4xl">
          {t.features.highlight.title}
        </h3>

        <p
          class="mt-4 max-w-md text-base leading-relaxed text-brand-600 lg:text-lg"
        >
          {t.features.highlight.description}
        </p>
      </div>

      <BusVisual locale={locale} />
    </div>

    {
      featuresMeta.map((feature) => {
        const Visual = visualComponents[feature.visual] as typeof FallbackVisual;
        const copy = t.features.items[feature.visual];

        return (
          <FeatureCard
            number={feature.number}
            title={copy.title}
            description={copy.description}
            class={feature.class}
          >
            <Visual locale={locale} />
          </FeatureCard>
        );
      })
    }
  </div>
</section>

<style is:global>
  .visual-pattern {
    background-image:
      linear-gradient(to right, var(--color-brand-200) 1px, transparent 1px),
      linear-gradient(to bottom, var(--color-brand-200) 1px, transparent 1px);
    background-size: 1.25rem 1.25rem;
    opacity: 0.35;
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      black 35%,
      transparent 80%
    );
    mask-image: radial-gradient(ellipse at center, black 35%, transparent 80%);
  }
</style>

<script>
  import { initFeaturesEntrance, refreshScrollTrigger } from "./features.animations";

  let cleanup: (() => void) | undefined;

  // astro:page-load already fires on the very first load too (not just on
  // soft navigations), so this is the sole init trigger — calling setup()
  // both immediately and on astro:page-load double-ran everything on cold
  // load, which is what caused overlapping GSAP timelines elsewhere on this
  // page and is avoided here defensively too.
  const setup = () => {
    cleanup?.();
    cleanup = initFeaturesEntrance();
    refreshScrollTrigger();
  };

  requestAnimationFrame(() => requestAnimationFrame(refreshScrollTrigger));
  window.addEventListener("load", refreshScrollTrigger);
  document.fonts?.ready?.then(refreshScrollTrigger);

  document.addEventListener("astro:page-load", setup);
  document.addEventListener("astro:before-swap", () => {
    cleanup?.();
    cleanup = undefined;
  });
</script>
