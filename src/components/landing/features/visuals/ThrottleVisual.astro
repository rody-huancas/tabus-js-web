---
import { Icon } from "astro-icon/components";
---

<div
  class="feature-visual relative mb-7 flex flex-1 min-h-40 items-center justify-center overflow-hidden rounded-2xl bg-brand-50/60 px-6 ring-1 ring-brand-900/5"
>
  <div class="visual-pattern absolute inset-0" aria-hidden="true"></div>

  <div class="relative flex flex-col items-center gap-4" aria-hidden="true">
    <div class="flex items-end gap-0.75">
      <span class="throttle-in h-5 w-1 rounded-full bg-brand-300"></span>
      <span class="throttle-in h-6 w-1 rounded-full bg-brand-300"></span>
      <span class="throttle-in h-4 w-1 rounded-full bg-brand-300"></span>
      <span class="throttle-in h-6 w-1 rounded-full bg-brand-300"></span>
      <span class="throttle-in h-5 w-1 rounded-full bg-brand-300"></span>
      <span class="throttle-in h-6 w-1 rounded-full bg-brand-300"></span>
      <span class="throttle-in h-4 w-1 rounded-full bg-brand-300"></span>
      <span class="throttle-in h-6 w-1 rounded-full bg-brand-300"></span>
    </div>

    <Icon name="lucide:gauge" class="h-5 w-5 text-brand-400" />

    <div class="flex items-center gap-4">
      <span class="throttle-out h-3 w-3 rounded-full bg-brand-600"></span>
      <span class="throttle-out h-3 w-3 rounded-full bg-brand-600"></span>
      <span class="throttle-out h-3 w-3 rounded-full bg-brand-600"></span>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { initReducedMotionLoop } from "../features.animations";

  const initLoop = () => {
    return initReducedMotionLoop(() => {
      const throttleIn  = gsap.utils.toArray<HTMLElement>(".throttle-in");
      const throttleOut = gsap.utils.toArray<HTMLElement>(".throttle-out");

      if (!throttleIn.length && !throttleOut.length) return;

      const tweens: Array<gsap.core.Timeline | gsap.core.Tween> = [];

      if (throttleIn.length) {
        tweens.push(
          gsap.to(throttleIn, {
            opacity      : () => gsap.utils.random(0.25, 1),
            duration     : 0.18,
            ease         : "power1.inOut",
            repeat       : -1,
            yoyo         : true,
            repeatRefresh: true,
            stagger      : { each: 0.05, from: "random" },
          }),
        );
      }

      if (throttleOut.length) {
        tweens.push(
          gsap
            .timeline({ repeat: -1, repeatDelay: 0.6 })
            .fromTo(
              throttleOut,
              { opacity: 0.3, scale: 0.8 },
              {
                opacity : 1,
                scale   : 1,
                duration: 0.25,
                ease    : "back.out(2)",
                stagger : 0.35,
              },
            )
            .to(
              throttleOut,
              { opacity: 0.3, scale: 0.8, duration: 0.3 },
              "+=0.4",
            ),
        );
      }

      return () => {
        tweens.forEach((tw) => tw.kill());
        gsap.set([".throttle-in", ".throttle-out"], { clearProps: "all" });
      };
    });
  }

  let cleanup: (() => void) | undefined;

  const setup = () => {
    cleanup?.();
    cleanup = initLoop();
  };

  document.addEventListener("astro:page-load", setup);
  document.addEventListener("astro:before-swap", () => {
    cleanup?.();
    cleanup = undefined;
  });
</script>
