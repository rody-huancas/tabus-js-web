---
import { Icon } from "astro-icon/components";

const rawCode = `import { Tabus } from 'tabus-js'

type Events = {
  'cart:add': { id: string }
  'cart:reset': void
}

const bus = new Tabus<Events>('shop')

// escucha en las otras pestañas
bus.on('cart:add', ({ id }) => {
  addToCart(id)
})

// emite desde esta
bus.emit('cart:add', { id: 'sku_42' })`;

const kw  = (s: string) => `<span class="text-brand-400">${s}</span>`;
const ty  = (s: string) => `<span class="text-amber-300">${s}</span>`;
const str = (s: string) => `<span class="text-green-400">${s}</span>`;
const cm  = (s: string) => `<span class="text-brand-400/50">${s}</span>`;

const codeHtml = [
  `${kw("import")} { ${ty("Tabus")} } ${kw("from")} ${str("'tabus-js'")}`,
  ``,
  `${kw("type")} ${ty("Events")} = {`,
  `  ${str("'cart:add'")}: { id: ${ty("string")} }`,
  `  ${str("'cart:reset'")}: ${ty("void")}`,
  `}`,
  ``,
  `${kw("const")} ${kw("bus")} = ${kw("new")} ${ty("Tabus")}&lt;${ty("Events")}&gt;(${str("'shop'")})`,
  ``,
  cm("// escucha en las otras pestañas"),
  `${kw("bus")}.on(${str("'cart:add'")}, ({ id }) =&gt; {`,
  `  addToCart(id)`,
  `})`,
  ``,
  cm("// emite desde esta"),
  `${kw("bus")}.emit(${str("'cart:add'")}, { id: ${str("'sku_42'")} })<span class="code-cursor">▍</span>`,
].join("\n");

const bullets = [
  { icon: "lucide:plug", label: "Creás el canal" },
  { icon: "lucide:ear", label: "Escuchás en las otras pestañas" },
  { icon: "lucide:send", label: "Emitís desde la tuya" },
];
---

<section class="mx-auto max-w-360 px-6 py-20 lg:px-12 lg:py-28">
  <div
    class="code-preview-grid grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16"
  >
    <div class="code-reveal order-2 lg:order-1">
      <div
        class="code-window relative overflow-hidden rounded-3xl border border-brand-900/10 bg-brand-900 shadow-2xl shadow-brand-900/15"
      >
        <div
          class="flex items-center gap-3 border-b border-white/10 bg-white/3 px-5 py-3.5"
        >
          <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
          <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
          <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>

          <span class="ml-2 font-mono text-xs text-brand-300/70">cart.ts</span>

          <button
            type="button"
            class="code-copy-btn ml-auto inline-flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 font-mono text-xs text-brand-300 transition-colors hover:bg-white/10 hover:text-white"
            data-code={rawCode}
            aria-label="Copiar código"
          >
            <Icon name="lucide:copy" class="code-copy-icon h-3.5 w-3.5" />
            <Icon
              name="lucide:check"
              class="code-copy-check hidden h-3.5 w-3.5 text-green-400"
            />
            <span class="code-copy-label">Copiar</span>
          </button>
        </div>

        <pre
          class="overflow-x-auto px-6 py-6 font-mono text-[0.85rem] leading-relaxed text-brand-200"><code set:html={codeHtml} /></pre>
      </div>
    </div>

    <div class="code-reveal order-1 flex flex-col justify-center lg:order-2">
      <p class="font-mono text-sm font-semibold text-brand-500">
        // la API completa
      </p>

      <h2
        class="mt-4 font-display text-3xl font-bold text-brand-900 sm:text-4xl"
      >
        Esto es todo lo que escribes
      </h2>

      <p class="mt-4 max-w-md text-lg leading-relaxed text-brand-700/90">
        Creas un canal tipado, escuchas en las demás pestañas, emites desde la
        tuya. No hay paso cuatro.
      </p>

      <ul class="mt-8 flex flex-col gap-4">
        {
          bullets.map((bullet) => (
            <li class="flex items-center gap-3 text-brand-700">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
                <Icon name={bullet.icon} class="h-4 w-4" />
              </span>
              <span class="text-sm font-medium">{bullet.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .code-cursor {
    display: inline-block;
    animation: code-cursor-blink 1s step-end infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .code-cursor {
      animation: none;
    }
  }

  @keyframes code-cursor-blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }
</style>

<script>
  const copyButton = document.querySelector<HTMLButtonElement>(".code-copy-btn");

  if (copyButton) {
    const icon  = copyButton.querySelector<HTMLElement>(".code-copy-icon");
    const check = copyButton.querySelector<HTMLElement>(".code-copy-check");
    const label = copyButton.querySelector<HTMLElement>(".code-copy-label");

    let resetTimeout: ReturnType<typeof setTimeout> | undefined;

    copyButton.addEventListener("click", async () => {
      const code = copyButton.dataset.code ?? "";

      try {
        await navigator.clipboard.writeText(code);
      } catch {
        return;
      }

      icon?.classList.add("hidden");
      check?.classList.remove("hidden");

      if (label) label.textContent = "Copiado";

      clearTimeout(resetTimeout);

      resetTimeout = setTimeout(() => {
        icon?.classList.remove("hidden");
        check?.classList.add("hidden");
        if (label) label.textContent = "Copiar";
      }, 1600);
    });
  }
</script>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let cleanup: (() => void) | undefined;

  const initCodePreviewEntrance = (): (() => void) => {
    const mm = gsap.matchMedia();

    mm.add("(prefers-reduced-motion: no-preference)", () => {
      const grid  = document.querySelector<HTMLElement>(".code-preview-grid");
      const items = gsap.utils.toArray<HTMLElement>(".code-reveal");

      if (!grid || !items.length) return;

      const revealTween = gsap.from(items, {
        opacity      : 0,
        y            : 24,
        duration     : 0.7,
        ease         : "power3.out",
        stagger      : 0.15,
        scrollTrigger: {
          trigger: grid,
          start  : "top 85%",
          once   : true,
        },
      });

      return () => {
        revealTween.scrollTrigger?.kill();
        revealTween.kill();
        gsap.set(items, { clearProps: "all" });
      };
    });

    return () => {
      mm.revert();
    };
  };

  const refreshScrollTrigger = (): void => {
    ScrollTrigger.refresh();
  };

  cleanup = initCodePreviewEntrance();

  requestAnimationFrame(() => requestAnimationFrame(refreshScrollTrigger));
  window.addEventListener("load", refreshScrollTrigger);
  document.fonts?.ready?.then(refreshScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    cleanup?.();
    cleanup = initCodePreviewEntrance();
    refreshScrollTrigger();
  });
</script>
