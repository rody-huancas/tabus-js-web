---
import { Icon } from "astro-icon/components";
---

<div class="hero-visual relative mx-auto w-full max-w-2xl lg:max-w-none">
  <div
    class="hero-browser relative z-10 overflow-hidden rounded-3xl border border-brand-200/80 bg-white shadow-2xl shadow-brand-900/10"
  >
    <div
      class="flex items-center gap-3 border-b border-brand-100 bg-brand-50/80 px-5 py-3.5"
    >
      <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
      <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
      <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
      <div
        class="ml-2 flex flex-1 items-center gap-2 rounded-xl bg-white px-4 py-2"
      >
        <svg
          class="h-4 w-4 text-brand-400"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M8 1a5 5 0 00-5 5v2a5 5 0 0010 0V6a5 5 0 00-5-5z"
            stroke="currentColor"
            stroke-width="1.5"></path>
          <path
            d="M6 11v1a2 2 0 004 0v-1"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
        <span class="truncate text-sm text-brand-600">app.mi-proyecto.dev</span>
      </div>
    </div>

    <div class="flex gap-1 border-b border-brand-100 bg-brand-50/50 px-4 pt-3">
      <div
        class="hero-tab flex items-center gap-2 rounded-t-xl border border-b-0 border-brand-200 bg-white px-4 py-2.5"
      >
        <span class="h-2 w-2 rounded-full bg-brand-500"></span>
        <span class="text-sm font-medium text-brand-900">Tienda</span>
        <span
          class="hero-counter ml-1 flex h-5 min-w-5 items-center justify-center rounded-full bg-accent px-1.5 text-xs font-bold text-white"
          >3</span
        >
      </div>
      <div
        class="hero-tab-2 flex items-center gap-2 rounded-t-xl px-4 py-2.5 opacity-60"
      >
        <span class="text-sm text-brand-600">Checkout</span>
      </div>
      <div
        class="hero-tab-3 flex items-center gap-2 rounded-t-xl px-4 py-2.5 opacity-40"
      >
        <span class="text-sm text-brand-600">Perfil</span>
      </div>
    </div>

    <div class="space-y-5 p-6 lg:p-8">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs tracking-wider text-brand-400 uppercase">
            Carrito compartido
          </p>
          <p class="mt-1 font-display text-2xl font-bold text-brand-900">
            Zapatillas Tabus
          </p>
        </div>
      </div>

      <div class="rounded-2xl bg-brand-50 p-5">
        <div class="flex items-center justify-between text-sm">
          <span class="text-brand-600">Estado sincronizado</span>
          <span class="flex items-center gap-1.5 text-green-600">
            <span class="h-2 w-2 rounded-full bg-green-500"></span>
            Activo
          </span>
        </div>
        <div class="mt-4 h-2.5 overflow-hidden rounded-full bg-brand-200">
          <div
            class="hero-progress h-full w-3/4 rounded-full bg-linear-to-r from-brand-500 to-brand-400"
          >
          </div>
        </div>
      </div>

      <div class="space-y-2 font-mono text-sm">
        <div
          class="hero-event flex items-center gap-3 rounded-xl bg-brand-900 px-4 py-3 text-brand-100"
        >
          <span class="text-accent">→</span>
          <span
            ><span class="text-brand-400">bus.</span>emit(<span
              class="text-green-400">'cart:add'</span
            >)</span
          >
        </div>
        <div
          class="hero-event-2 flex items-center gap-3 rounded-xl border border-brand-200 px-4 py-3 text-brand-700"
        >
          <span class="text-brand-400">←</span>
          <span>Pestaña B recibió el evento</span>
        </div>
      </div>
    </div>
  </div>

  <div
    class="hero-bubble absolute -top-4 right-2 z-20 max-w-[calc(100%-1rem)] rounded-2xl border border-brand-200/80 bg-white px-4 py-3 shadow-xl sm:right-3 sm:px-5 sm:py-4 lg:-right-4"
  >
    <div class="flex items-center gap-3">
      <div
        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-accent/15 text-accent sm:h-10 sm:w-10"
      >
        <Icon name="lucide:zap" class="h-4 w-4 sm:h-5 sm:w-5" />
      </div>
      <div class="min-w-0">
        <p
          class="truncate font-display text-sm font-bold text-brand-900 sm:text-base"
        >
          Pestaña A → B
        </p>
        <p class="truncate text-xs text-brand-500 sm:text-sm">Evento en ~0ms</p>
      </div>
    </div>
  </div>

  <svg
    class="pointer-events-none absolute -right-6 top-1/2 z-0 hidden h-32 w-32 text-brand-300/40 lg:block"
    viewBox="0 0 100 100"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M0 50 Q50 20 100 50"
      stroke="currentColor"
      stroke-width="2"
      stroke-dasharray="6 4"></path>
    <circle cx="100" cy="50" r="4" fill="currentColor"></circle>
  </svg>
</div>
