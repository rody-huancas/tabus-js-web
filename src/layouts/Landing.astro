---
import "../styles/global.css";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Tabus.js",
  description = "Librería ligera para gestionar tabs en JavaScript.",
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <script is:inline>
      (function () {
        var html = document.documentElement;
        if (
          window.matchMedia &&
          window.matchMedia("(prefers-reduced-motion: no-preference)").matches
        ) {
          html.classList.add("hero-anim-pending");
          // Safety net: never leave the hero permanently hidden if the
          // animation script fails to load/run for any reason.
          window.setTimeout(function () {
            html.classList.remove("hero-anim-pending");
          }, 2000);
        }
      })();
    </script>
  </head>

  <body class="min-h-screen bg-brand-50 font-sans text-brand-900">
    <header
      id="site-header"
      class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-colors duration-300 [&.scrolled]:border-brand-200/60 [&.scrolled]:bg-brand-50/90 [&.scrolled]:backdrop-blur-lg"
    >
      <div
        class="mx-auto flex h-16 max-w-360 items-center justify-between gap-4 px-6 md:h-20 lg:px-12"
      >
        <a
          href="/"
          class="flex shrink-0 items-center gap-3 font-display text-lg font-bold tracking-tight"
          aria-label="tabus-js — inicio"
        >
          <img
            src="/tabus-logo.png"
            alt="Logo de tabus-js"
            class="h-9 rounded-lg md:h-11"
          />
        </a>

        <div class="flex items-center gap-1 sm:gap-2">
          <nav
            class="mr-1 hidden items-center gap-1 text-[0.9375rem] font-medium text-brand-600 md:flex"
            aria-label="Principal"
          >
            <a
              href="/docs"
              class="rounded-lg px-3 py-2 transition-colors hover:bg-brand-900/5 hover:text-brand-900"
              >Docs</a
            >
            <a
              href="#demo"
              data-scroll-target="demo"
              class="rounded-lg px-3 py-2 transition-colors hover:bg-brand-900/5 hover:text-brand-900"
              >Demo</a
            >
          </nav>

          <a
            href="https://github.com/rody-huancas/tabus-js"
            target="_blank"
            rel="noreferrer"
            aria-label="Ver repositorio en GitHub"
            class="hidden rounded-xl p-2.5 text-brand-600 transition-colors hover:bg-brand-100 md:inline-flex"
          >
            <Icon name="simple-icons:github" class="h-5 w-5" />
          </a>

          <a
            href="https://www.npmjs.com/package/tabus-js"
            target="_blank"
            rel="noreferrer"
            aria-label="Ver paquete en npm"
            class="hidden rounded-xl p-2.5 text-brand-600 transition-colors hover:bg-brand-100 md:inline-flex"
          >
            <Icon name="simple-icons:npm" class="h-5 w-5" />
          </a>

          <span
            id="header-cta-wrap"
            class="header-cta-wrap inline-flex shrink-0 items-center"
          >
            <a
              id="header-cta"
              href="/docs/getting-started/introduccion"
              aria-hidden="true"
              tabindex="-1"
              class="group inline-flex shrink-0 items-center gap-1.5 rounded-md bg-brand-600 px-4 py-2 text-sm font-semibold text-on-accent shadow-[0_3px_12px_-4px_var(--brand-glow-subtle)] transition-all duration-200 hover:-translate-y-px hover:bg-brand-500 hover:shadow-[0_5px_16px_-4px_var(--brand-glow-subtle-hover)] active:translate-y-0 active:shadow-[0_2px_8px_-4px_var(--brand-glow-subtle-active)] motion-reduce:hover:translate-y-0 motion-reduce:duration-0 sm:px-5 sm:py-2.5"
            >
              Empezar
              <Icon
                name="lucide:arrow-right"
                class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-0.5 motion-reduce:group-hover:translate-x-0"
              />
            </a>
          </span>
        </div>
      </div>
    </header>

    <style>
      .header-cta-wrap {
        max-width: 0;
        margin-left: 0;
        overflow: hidden;
        transition:
          max-width 1s cubic-bezier(0.16, 1, 0.3, 1),
          margin-left 1s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .header-cta-wrap.is-visible {
        max-width: 11rem;
        margin-left: 0.25rem;
      }

      #header-cta {
        opacity: 0;
        pointer-events: none;
        transform: translateX(-8px) scale(0.96);
        transition:
          opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
          transform 1s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .header-cta-wrap.is-visible #header-cta {
        opacity: 1;
        pointer-events: auto;
        transform: translateX(0) scale(1);
      }

      @media (prefers-reduced-motion: reduce) {
        .header-cta-wrap,
        #header-cta {
          transition: none;
        }
      }

      .scroll-top-btn {
        opacity: 0;
        pointer-events: none;
        transform: translateY(0.5rem);
        transition:
          opacity 0.25s ease,
          transform 0.25s ease,
          background-color 0.2s ease;
      }

      .scroll-top-btn.is-visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        .scroll-top-btn {
          transition: opacity 0.15s ease;
        }
      }
    </style>

    <slot />

    <button
      id="scroll-top"
      type="button"
      aria-label="Volver arriba"
      class="scroll-top-btn fixed right-5 bottom-5 z-40 inline-flex h-11 w-11 items-center justify-center rounded-full bg-brand-600 text-on-accent shadow-[0_8px_24px_-6px_var(--brand-glow-subtle)] hover:bg-brand-500 sm:right-8 sm:bottom-8"
    >
      <Icon name="lucide:arrow-up" class="h-5 w-5" />
    </button>

    <script is:inline>
      (function () {
        const header = document.getElementById("site-header");
        if (!header) return;
        const SCROLL_THRESHOLD = 40;

        const updateHeader = () => {
          header.classList.toggle(
            "scrolled",
            window.scrollY > SCROLL_THRESHOLD,
          );
        }

        updateHeader();
        window.addEventListener("scroll", updateHeader, { passive: true });

        const headerCtaWrap = document.getElementById("header-cta-wrap");
        const headerCta     = document.getElementById("header-cta");
        const heroCta       = document.getElementById("hero-cta");

        if (!headerCtaWrap || !headerCta || !heroCta) return;

        const setHeaderCtaVisible = (visible) => {
          headerCtaWrap.classList.toggle("is-visible", visible);
          if (visible) {
            headerCta.removeAttribute("aria-hidden");
            headerCta.removeAttribute("tabindex");
          } else {
            headerCta.setAttribute("aria-hidden", "true");
            headerCta.setAttribute("tabindex", "-1");
          }
        }

        if (!("IntersectionObserver" in window)) {
          setHeaderCtaVisible(true);
          return;
        }

        let ctaObserver;

        const createCtaObserver = () => {
          if (ctaObserver) ctaObserver.disconnect();

          const headerHeight = header.getBoundingClientRect().height;
          
          ctaObserver = new IntersectionObserver(
            ([entry]) => setHeaderCtaVisible(!entry.isIntersecting),
            { rootMargin: `-${Math.ceil(headerHeight)}px 0px 0px 0px` },
          );
          ctaObserver.observe(heroCta);
        };

        createCtaObserver();

        let resizeTimeout;
        window.addEventListener(
          "resize",
          function () {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(createCtaObserver, 150);
          },
          { passive: true },
        );
      })();
    </script>

    <script is:inline>
      (function () {
        document.addEventListener("click", function (event) {
          const trigger = event.target.closest("[data-scroll-target]");
          if (!trigger) return;

          const targetId = trigger.dataset.scrollTarget;
          const target   = targetId ? document.getElementById(targetId) : null;
          if (!target) return;

          event.preventDefault();

          const reduced = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
          ).matches;

          target.scrollIntoView({
            behavior: reduced ? "auto" : "smooth",
            block   : "start",
          });

          if (window.history && window.history.replaceState) {
            window.history.replaceState(
              null,
              "",
              window.location.pathname + window.location.search,
            );
          }
        });
      })();
    </script>

    <script is:inline>
      (function () {
        const scrollTopBtn = document.getElementById("scroll-top");
        if (!scrollTopBtn) return;

        const SHOW_AT = 100;

        const updateVisibility = () => {
          scrollTopBtn.classList.toggle("is-visible", window.scrollY > SHOW_AT);
        };

        updateVisibility();
        window.addEventListener("scroll", updateVisibility, { passive: true });

        scrollTopBtn.addEventListener("click", () => {
          const reduced = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
          ).matches;

          window.scrollTo({ top: 0, behavior: reduced ? "auto" : "smooth" });
        });
      })();
    </script>

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { initHeroAnimations } from "../components/landing/hero/hero.animations";

      gsap.registerPlugin(ScrollTrigger);

      let cleanup: (() => void) | undefined;
      let heroPlayed = false;

      const initAnimations = () => {
        const mm = gsap.matchMedia();

        mm.add("(prefers-reduced-motion: no-preference)", () => {
          const heroCleanup = heroPlayed ? undefined : initHeroAnimations();
          if (heroCleanup) heroPlayed = true;

          const demoSection = document.querySelector(".demo-reveal");
          if (demoSection) {
            gsap.from(demoSection, {
              opacity      : 0,
              y            : 40,
              duration     : 0.8,
              ease         : "power2.out",
              scrollTrigger: {
                trigger: demoSection,
                start  : "top 80%",
              },
            });
          }

          return () => {
            heroCleanup?.();
          };
        });

        return () => {
          mm.revert();
          ScrollTrigger.getAll().forEach((trigger) => trigger.kill());
        };
      }

      cleanup = initAnimations();

      document.addEventListener("astro:page-load", () => {
        cleanup?.();
        cleanup = initAnimations();
      });
    </script>
  </body>
</html>
