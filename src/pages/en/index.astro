---
import CTA from "../../components/landing/CTA.astro";
import Hero from "../../components/landing/hero/Hero.astro";
import Compat from "../../components/landing/compat/Compat.astro";
import Footer from "../../components/landing/Footer.astro";
import Landing from "../../layouts/Landing.astro";
import Features from "../../components/landing/features/Features.astro";
import CodePreview from "../../components/landing/CodePreview.astro";
import LiveTabsDemo from "../../components/demo/LiveTabsDemo";
import { landing } from "../../i18n/landing";

const locale = "en" as const;
const t = landing[locale];
---

<Landing locale={locale}>
  <Hero locale={locale} />

  <section
    id="demo"
    class="demo-reveal mx-auto max-w-360 scroll-mt-24 px-6 py-16 lg:px-12"
  >
    <h2 class="mb-8 text-center text-2xl font-bold text-brand-900">
      {t.demoSection.heading}
    </h2>
    <LiveTabsDemo client:visible locale={locale} />
  </section>

  <Features locale={locale} />
  <CodePreview locale={locale} />
  <Compat locale={locale} />
  <CTA locale={locale} />
  <Footer locale={locale} />
</Landing>
